using System;

class Hamburguesa
{
    protected string nombre;
    protected string tipoPan;
    protected string carne;
    protected double precioBase;

    protected string adicional1;
    protected double precioAdicional1;

    protected string adicional2;
    protected double precioAdicional2;

    protected string adicional3;
    protected double precioAdicional3;

    protected string adicional4;
    protected double precioAdicional4;

    public Hamburguesa(string nombre, string tipoPan, string carne, double precioBase)
    {
        this.nombre = nombre;
        this.tipoPan = tipoPan;
        this.carne = carne;
        this.precioBase = precioBase;
    }

    public virtual void AgregarAdicional1(string nombre, double precio)
    {
        adicional1 = nombre;
        precioAdicional1 = precio;
    }

    public virtual void AgregarAdicional2(string nombre, double precio)
    {
        adicional2 = nombre;
        precioAdicional2 = precio;
    }

    public virtual void AgregarAdicional3(string nombre, double precio)
    {
        adicional3 = nombre;
        precioAdicional3 = precio;
    }

    public virtual void AgregarAdicional4(string nombre, double precio)
    {
        adicional4 = nombre;
        precioAdicional4 = precio;
    }

    public virtual double ItemizarHamburguesa()
    {
        double total = precioBase;

        Console.WriteLine("Hamburguesa: " + nombre);
        Console.WriteLine("Pan: " + tipoPan);
        Console.WriteLine("Carne: " + carne);
        Console.WriteLine("Precio base: RD$" + precioBase.ToString("F2"));

        if (adicional1 != null)
        {
            Console.WriteLine("Adicional agregado: " + adicional1 + " - RD$" + precioAdicional1.ToString("F2"));
            total += precioAdicional1;
        }

        if (adicional2 != null)
        {
            Console.WriteLine("Adicional agregado: " + adicional2 + " - RD$" + precioAdicional2.ToString("F2"));
            total += precioAdicional2;
        }

        if (adicional3 != null)
        {
            Console.WriteLine("Adicional agregado: " + adicional3 + " - RD$" + precioAdicional3.ToString("F2"));
            total += precioAdicional3;
        }

        if (adicional4 != null)
        {
            Console.WriteLine("Adicional agregado: " + adicional4 + " - RD$" + precioAdicional4.ToString("F2"));
            total += precioAdicional4;
        }

        Console.WriteLine("Total de la hamburguesa: RD$" + total.ToString("F2"));
        return total;
    }
}

class HamburguesaSaludable : Hamburguesa
{
    private string adicionalSaludable1;
    private double precioAdicionalSaludable1;

    private string adicionalSaludable2;
    private double precioAdicionalSaludable2;

    public HamburguesaSaludable(string carne, double precioBase)
        : base("Hamburguesa Saludable", "Pan Integral", carne, precioBase)
    {
    }

    public void AgregarAdicionalSaludable1(string nombre, double precio)
    {
        adicionalSaludable1 = nombre;
        precioAdicionalSaludable1 = precio;
    }

    public void AgregarAdicionalSaludable2(string nombre, double precio)
    {
        adicionalSaludable2 = nombre;
        precioAdicionalSaludable2 = precio;
    }

    public override double ItemizarHamburguesa()
    {
        double total = base.ItemizarHamburguesa();

        if (adicionalSaludable1 != null)
        {
            Console.WriteLine("Adicional saludable: " + adicionalSaludable1 + " - RD$" + precioAdicionalSaludable1.ToString("F2"));
            total += precioAdicionalSaludable1;
        }

        if (adicionalSaludable2 != null)
        {
            Console.WriteLine("Adicional saludable: " + adicionalSaludable2 + " - RD$" + precioAdicionalSaludable2.ToString("F2"));
            total += precioAdicionalSaludable2;
        }

        Console.WriteLine("Total de la hamburguesa saludable: RD$" + total.ToString("F2"));
        return total;
    }
}

